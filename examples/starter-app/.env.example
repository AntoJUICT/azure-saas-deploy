# Database
# Lokaal: gebruik een lokale PostgreSQL of Docker
# Azure: wordt automatisch geconfigureerd via gedeelde infrastructuur
DATABASE_URL=postgresql://pgadmin:password@localhost:5432/starter_app?sslmode=disable

# NextAuth
AUTH_SECRET=vervang-dit-met-openssl-rand-base64-32
AUTH_URL=https://starter-app.example.com

# Microsoft Entra ID (per project — Azure portal > App registrations)
AUTH_MICROSOFT_ENTRA_ID_ID=your-client-id
AUTH_MICROSOFT_ENTRA_ID_SECRET=your-client-secret
AUTH_MICROSOFT_ENTRA_ID_TENANT_ID=organizations

# Azure Storage
# Lokaal: gedeelde credentials worden geladen uit ~/.azure-saas-deploy/shared.env
# Azure: geconfigureerd via Key Vault + Managed Identity
AZURE_STORAGE_CONNECTION_STRING=DefaultEndpointsProtocol=https;AccountName=...;AccountKey=...
AZURE_STORAGE_CONTAINER=starter-app-files
AZURE_STORAGE_URL=https://youraccount.blob.core.windows.net
